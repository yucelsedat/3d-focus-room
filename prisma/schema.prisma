generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Room {
  id           String         @id
  name         String
  roomType     String         @default("room")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  parentId     String?
  doors        Door[]
  floor        Floor?
  media        Media[]
  parent       Room?          @relation("RoomTree", fields: [parentId], references: [id])
  children     Room[]         @relation("RoomTree")
  categories   RoomCategory[]
  specialDoors SpecialDoor[]  @relation("SpecialDoorSource")
  targetedBy   SpecialDoor[]  @relation("SpecialDoorTarget")
}

model Media {
  id       BigInt  @id
  roomId   String
  tileId   String
  type     String
  url      String?
  content  String?
  width    Float
  height   Float
  posX     Float
  posY     Float
  posZ     Float
  rotX     Float
  rotY     Float
  rotZ     Float
  rotOrder String  @default("XYZ")
  room     Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Door {
  id      Int     @id @default(autoincrement())
  roomId  String
  doorId  Int
  isOuter Boolean @default(false)
  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, doorId, isOuter])
}

model Floor {
  roomId  String @id
  texture String @default("zemin.png")
  room    Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Category {
  id    Int            @id @default(autoincrement())
  name  String         @unique
  rooms RoomCategory[]
}

model RoomCategory {
  roomId     String
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([roomId, categoryId])
}

model SpecialDoor {
  id           Int     @id @default(autoincrement())
  roomId       String
  anchorId     Int
  targetRoomId String
  isOuter      Boolean @default(false)
  room         Room    @relation("SpecialDoorSource", fields: [roomId], references: [id], onDelete: Cascade)
  target       Room    @relation("SpecialDoorTarget", fields: [targetRoomId], references: [id], onDelete: Cascade)

  @@unique([roomId, anchorId, isOuter])
}
